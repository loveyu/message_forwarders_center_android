<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 添加网络访问权限 -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <!-- WiFi 信息访问权限（Android 13+需要，用于获取SSID/BSSID） -->
    <uses-permission android:name="android.permission.NEARBY_WIFI_DEVICES" />
    <!-- 定位权限（部分设备获取WiFi信息仍需要） -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <!-- 后台定位权限（Android 10+，后台获取WiFi SSID/BSSID需要） -->
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />
    <!-- 添加前台服务权限 -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- 添加唤醒锁权限（保持CPU在熄屏后运行） -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!-- 添加数据同步类型前台服务权限（Android 14及以上需要） -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <!-- 添加开机自启动权限 -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- 添加电池优化豁免权限 -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <!-- 添加通知权限（Android 13及以上需要） -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- 添加读取媒体图片权限（Android 13及以上需要） -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <!-- 添加读取外部存储权限（Android 12及以下需要） -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" android:maxSdkVersion="32" />
    <!-- 添加写入外部存储权限（Android 10及以下需要） -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" android:maxSdkVersion="29" />
    <!-- 管理所有文件权限（Android 11+需要，用于 sdcard:// 路径写入） -->
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE" />

     <application
         android:name=".Application"
         android:allowBackup="true"
         android:dataExtractionRules="@xml/data_extraction_rules"
         android:fullBackupContent="@xml/backup_rules"
         android:icon="@mipmap/ic_launcher"
         android:label="@string/app_name"
         android:networkSecurityConfig="@xml/network_security_config"
         android:roundIcon="@mipmap/ic_launcher_round"
         android:supportsRtl="true"
         android:theme="@style/Theme.MessageForwardersCenter">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:theme="@style/Theme.MessageForwardersCenter">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ConfigActivity"
            android:exported="false"
            android:theme="@style/Theme.MessageForwardersCenter" />

        <activity
            android:name=".HelpActivity"
            android:exported="false"
            android:theme="@style/Theme.MessageForwardersCenter" />

        <activity
            android:name=".SettingsActivity"
            android:exported="false"
            android:theme="@style/Theme.MessageForwardersCenter" />

        <activity
            android:name=".LicenseActivity"
            android:exported="false"
            android:theme="@style/Theme.MessageForwardersCenter" />

        <activity
            android:name=".NotifyDetailActivity"
            android:exported="false"
            android:theme="@style/Theme.MessageForwardersCenter" />

        <activity
            android:name=".ClipboardDetailActivity"
            android:exported="false"
            android:theme="@style/Theme.MessageForwardersCenter" />

        <activity
            android:name=".ClipboardPreviewActivity"
            android:exported="false"
            android:theme="@style/Theme.MessageForwardersCenter" />

        <service
            android:name=".service.ForwardService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!-- 输入法切换浮动Activity -->
        <activity
            android:name=".InputMethodFloatingActivity"
            android:exported="false"
            android:theme="@android:style/Theme.Translucent.NoTitleBar"
            android:excludeFromRecents="true"
            android:finishOnTaskLaunch="true"
            android:noHistory="true"
            android:taskAffinity="" />

        <!-- 状态控制浮动Activity -->
        <activity
            android:name=".StatusFloatingActivity"
            android:exported="false"
            android:theme="@android:style/Theme.Translucent.NoTitleBar"
            android:excludeFromRecents="true"
            android:finishOnTaskLaunch="true"
            android:noHistory="true"
            android:taskAffinity="" />

        <receiver
            android:name=".receiver.BootCompletedReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
